{
  "name": "@benflux-ui/themes",
  "version": "0.1.0",
  "description": "Theme system and design tokens for Benflux UI",
  "license": "MIT",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./css": "./dist/themes.css"
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "zustand": "^4.5.2"
  },
  "peerDependencies": {
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0"
  },
  "devDependencies": {
    "@benflux-ui/typescript-config": "workspace:*",
    "@types/react": "^18.3.1",
    "tsup": "^8.0.2",
    "typescript": "^5.4.5"
  }
}
