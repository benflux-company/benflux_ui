{
  "name": "benflux-ui",
  "version": "0.1.0",
  "description": "CLI for adding Benflux UI components to your project",
  "keywords": ["benflux-ui", "cli", "components", "react", "nextjs", "ui"],
  "license": "MIT",
  "homepage": "https://benflux-ui.dev",
  "repository": {
    "type": "git",
    "url": "https://github.com/benflux20/benflux-ui.git",
    "directory": "packages/cli"
  },
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "bin": {
    "benflux-ui": "./dist/bin/benflux-ui.js"
  },
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@clack/prompts": "^0.7.0",
    "chalk": "^5.3.0",
    "commander": "^12.1.0",
    "execa": "^9.2.0",
    "fs-extra": "^11.2.0",
    "glob": "^11.0.0",
    "ora": "^8.0.1",
    "picocolors": "^1.0.1",
    "semver": "^7.6.2",
    "validate-npm-package-name": "^5.0.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@benflux-ui/typescript-config": "workspace:*",
    "@types/fs-extra": "^11.0.4",
    "@types/semver": "^7.5.8",
    "tsup": "^8.0.2",
    "typescript": "^5.4.5"
  }
}
